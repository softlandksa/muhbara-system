# ── Database ──────────────────────────────────────────────────────────────────
# Pooled connection (used by the app at runtime via PgBouncer)
DATABASE_URL="postgresql://user:password@host:6543/db?pgbouncer=true"

# Direct connection (used only by Prisma migrations)
DIRECT_URL="postgresql://user:password@host:5432/db"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="https://your-app.vercel.app"

# ── File Storage (Vercel Blob) ─────────────────────────────────────────────────
# Required in production. Without this, file uploads fail with ENOENT.
# How to obtain:
#   1. Open your Vercel project → Storage tab → Create → Blob store
#   2. Connect the store to your project
#   3. Copy the BLOB_READ_WRITE_TOKEN from the .env.local Vercel generates
#
# Local development: omit this variable and files are saved to ./uploads/ instead.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxx"
