generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String           @id @default(cuid())
  name                String
  email               String           @unique
  passwordHash        String
  role                Role             @default(SALES)
  teamId              String?
  isActive            Boolean          @default(true)
  avatar              String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  activityLogs        ActivityLog[]
  approvedCommissions Commission[]     @relation("CommissionApprover")
  commissions         Commission[]
  dailyReports        DailyReport[]
  employeeTargets     EmployeeTarget[]
  followUpNotes       FollowUpNote[]
  notifications       Notification[]
  orders              Order[]          @relation("OrderCreator")
  auditLogs           OrderAuditLog[]
  shippingActions     ShippingInfo[]
  managedTeams        Team[]           @relation("TeamManager")
  team                Team?            @relation("TeamMembers", fields: [teamId], references: [id])
  userTargets         UserTarget[]
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  managerId String
  createdAt DateTime @default(now())
  orders    Order[]
  manager   User     @relation("TeamManager", fields: [managerId], references: [id])
  members   User[]   @relation("TeamMembers")
}

model Order {
  id                 String                @id @default(cuid())
  orderNumber        String                @unique
  orderDate          DateTime              @default(now())
  customerName       String
  phone              String
  address            String
  countryId          String
  currencyId         String
  paymentMethodId    String
  totalAmount        Float                 @default(0)
  notes              String?
  createdById        String
  teamId             String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deletedAt          DateTime?
  isRepeatCustomer   Boolean               @default(false)
  repeatCustomerNote String?
  statusId           String
  followUpNotes      FollowUpNote[]
  notifications      Notification[]
  country            Country               @relation(fields: [countryId], references: [id])
  createdBy          User                  @relation("OrderCreator", fields: [createdById], references: [id])
  currency           Currency              @relation(fields: [currencyId], references: [id])
  paymentMethod      PaymentMethod         @relation(fields: [paymentMethodId], references: [id])
  status             ShippingStatusPrimary @relation(fields: [statusId], references: [id])
  team               Team?                 @relation(fields: [teamId], references: [id])
  auditLogs          OrderAuditLog[]
  items              OrderItem[]
  shippingInfo       ShippingInfo?

  @@index([deletedAt])
  @@index([statusId])
  @@index([teamId])
  @@index([createdById])
  @@index([orderDate])
  @@index([countryId])
  @@index([currencyId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt, statusId])
  @@index([deletedAt, teamId])
  @@index([deletedAt, createdById])
  @@index([deletedAt, orderDate])
  @@index([deletedAt, updatedAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model OrderAuditLog {
  id          String   @id @default(cuid())
  orderId     String
  action      String
  fieldName   String?
  oldValue    String?
  newValue    String?
  changedById String
  changedAt   DateTime @default(now())
  ipAddress   String?
  changedBy   User     @relation(fields: [changedById], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([changedById])
  @@index([changedAt])
}

model ShippingInfo {
  id                  String             @id @default(cuid())
  orderId             String             @unique
  shippingCompanyId   String
  trackingNumber      String?
  shippedById         String
  shippedAt           DateTime           @default(now())
  deliveredAt         DateTime?
  notes               String?
  shippingSubStatusId String?
  order               Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shippedBy           User               @relation(fields: [shippedById], references: [id])
  shippingCompany     ShippingCompany    @relation(fields: [shippingCompanyId], references: [id])
  shippingSubStatus   ShippingStatusSub? @relation(fields: [shippingSubStatusId], references: [id])

  @@index([shippingCompanyId])
  @@index([shippedById])
  @@index([shippedAt])
  @@index([shippingSubStatusId])
}

model FollowUpNote {
  id          String   @id @default(cuid())
  orderId     String
  note        String
  createdById String
  createdAt   DateTime @default(now())
  createdBy   User     @relation(fields: [createdById], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdById])
}

model Country {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  phoneCode   String?
  phoneFormat String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  orders      Order[]
}

model Currency {
  id              String           @id @default(cuid())
  name            String           @unique
  code            String           @unique
  symbol          String
  isActive        Boolean          @default(true)
  deletedAt       DateTime?
  commissions     Commission[]
  commissionRules CommissionRule[]
  employeeTargets EmployeeTarget[]
  orders          Order[]
}

model PaymentMethod {
  id        String    @id @default(cuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  orders    Order[]
}

model ShippingCompany {
  id           String         @id @default(cuid())
  name         String         @unique
  trackingUrl  String?
  isActive     Boolean        @default(true)
  deletedAt    DateTime?
  shippingInfo ShippingInfo[]
}

model ShippingStatusPrimary {
  id        String              @id @default(cuid())
  name      String              @unique
  color     String              @default("#6b7280")
  sortOrder Int                 @default(0)
  isActive  Boolean             @default(true)
  deletedAt DateTime?
  orders    Order[]
  subs      ShippingStatusSub[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("ShippingStatus")
}

model ShippingStatusSub {
  id                  String                @id @default(cuid())
  primaryId           String
  name                String
  colorOverride       String?
  sortOrder           Int                   @default(0)
  isActive            Boolean               @default(true)
  deletedAt           DateTime?
  marksOrderDelivered Boolean               @default(false)
  shippingInfos       ShippingInfo[]
  primary             ShippingStatusPrimary @relation(fields: [primaryId], references: [id])

  @@unique([primaryId, name])
  @@index([primaryId])
  @@index([isActive])
}

model Product {
  id           String      @id @default(cuid())
  name         String
  sku          String?     @unique
  defaultPrice Float       @default(0)
  isActive     Boolean     @default(true)
  deletedAt    DateTime?
  orderItems   OrderItem[]

  @@index([isActive])
  @@index([deletedAt])
}

model DailyReport {
  id         String   @id @default(cuid())
  userId     String
  reportDate DateTime @db.Date
  notes      String?
  createdAt  DateTime @default(now())
  reportData Json?
  shiftEnd   String?
  shiftStart String?
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, reportDate])
  @@index([userId])
  @@index([reportDate])
}

model CommissionRule {
  id               String         @id @default(cuid())
  name             String
  roleType         Role
  minOrders        Int
  maxOrders        Int?
  commissionAmount Float
  commissionType   CommissionType
  currencyId       String
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  commissions      Commission[]
  currency         Currency       @relation(fields: [currencyId], references: [id])

  @@index([roleType, currencyId])
  @@index([isActive])
}

model UserTarget {
  id           String   @id @default(cuid())
  userId       String
  year         Int
  month        Int
  targetOrders Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, year, month])
}

model EmployeeTarget {
  id                        String    @id @default(cuid())
  userId                    String
  periodStart               DateTime  @db.Date
  periodEnd                 DateTime  @db.Date
  targetDeliveredOrderCount Int?
  targetRevenue             Float?
  currencyId                String?
  notes                     String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  currency                  Currency? @relation(fields: [currencyId], references: [id])
  user                      User      @relation(fields: [userId], references: [id])

  @@unique([userId, periodStart, periodEnd])
  @@index([userId])
  @@index([periodStart, periodEnd])
}

model Commission {
  id                   String           @id @default(cuid())
  userId               String
  periodStart          DateTime
  periodEnd            DateTime
  totalDeliveredOrders Int
  ruleId               String?          // nullable: piecewise calculation spans multiple brackets
  breakdown            Json?            // BracketBreakdown[] snapshot for audit
  commissionAmount     Float
  currencyId           String
  status               CommissionStatus @default(PENDING)
  calculatedAt         DateTime         @default(now())
  approvedById         String?
  approvedBy           User?            @relation("CommissionApprover", fields: [approvedById], references: [id])
  currency             Currency         @relation(fields: [currencyId], references: [id])
  rule                 CommissionRule?  @relation(fields: [ruleId], references: [id])
  user                 User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([periodStart])
  @@index([userId, status])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  title          String
  message        String
  type           NotificationType
  relatedOrderId String?
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  relatedOrder   Order?           @relation(fields: [relatedOrderId], references: [id])
  user           User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@index([entityType, createdAt])
}

enum Role {
  ADMIN
  SALES_MANAGER
  SALES
  SHIPPING
  FOLLOWUP
  GENERAL_MANAGER
  SUPPORT
  HR
}

enum CommissionType {
  FIXED
  PERCENTAGE
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
}

enum NotificationType {
  ORDER_STATUS
  NEW_REPORT
  COMMISSION
  SYSTEM
}
